# Network Monitor — Environment Variables
# Copy this file to .env and fill in the values.

# =====================
# REQUIRED — Backend
# =====================

# JWT signing key. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Admin password for the Settings page
ADMIN_PASSWORD=your-strong-password-here

# =====================
# OPTIONAL — Backend
# =====================

# Restrict CORS to your frontend origin (recommended in production)
# FRONTEND_ORIGIN=https://monitor.yourdomain.com

# =====================
# OPTIONAL — Frontend
# =====================

# Backend API URL (only needed for local development without Docker)
# VITE_API_URL=http://localhost:8000
